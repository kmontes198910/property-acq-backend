<jasperReport name="receta_optometric" language="javascript" columnCount="1" printOrder="Horizontal" pageWidth="595" pageHeight="842" orientation="Landscape" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="401f652f-142a-4557-8107-c238a25df9bc" floatColumnFooter="true">
