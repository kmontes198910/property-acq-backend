	<dataset name="Diagnosis" uuid="3d07685b-dbe9-4872-846d-996e99585fff">
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="KyneSoft"/>
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w1" value="0"/>
		<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w2" value="1000"/>
		<parameter name="id_consulta" class="java.lang.String"/>
		<query language="sql"><![CDATA[SELECT
     diagnosis.icdcode as diagnosis_code,
      diagnosis.description as diagnosis
FROM treatment.diagnosis 
         INNER JOIN  treatment.externalconsultation ON  diagnosis.external_consultation_id = treatment.externalconsultation.id     
         WHERE diagnosis.external_consultation_id = $P{id_consulta}::uuid]]></query>
		<field name="diagnosis_code" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="diagnosis_code"/>
			<property name="com.jaspersoft.studio.field.label" value="diagnosis_code"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="diagnosis"/>
		</field>
		<field name="diagnosis" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="diagnosis"/>
			<property name="com.jaspersoft.studio.field.label" value="diagnosis"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="diagnosis"/>
		</field>
	</dataset>
	<dataset name="Tratamiento" uuid="9af41ffe-3a68-4c6f-90c9-0bc4b1b08248">
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="KyneSoft"/>
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w1" value="143"/>
		<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w2" value="850"/>
		<parameter name="id_consulta" class="java.lang.String"/>
		<query language="sql"><![CDATA[SELECT
      medicines.name  as medicament,
      treatment.description AS treatment_desc
FROM  treatment.medicines  
         INNER JOIN  treatment.treatment ON  treatment.medicines_id =  medicines.id 
         INNER JOIN  treatment.externalconsultation ON   treatment.external_consultation_id  = treatment.externalconsultation.id     
         WHERE treatment.externalconsultation.id = $P{id_consulta}::uuid]]></query>
		<field name="medicament" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="medicament"/>
			<property name="com.jaspersoft.studio.field.label" value="medicament"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="medicines"/>
		</field>
		<field name="treatment_desc" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="treatment_desc"/>
			<property name="com.jaspersoft.studio.field.label" value="treatment_desc"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="treatment"/>
		</field>
	</dataset>
	<parameter name="id_consulta" class="java.lang.String"/>
	<parameter name="insuranse" class="java.lang.String"/>
	<query language="SQL"><![CDATA[SELECT
    TO_CHAR(treatment.externalconsultation.consultationtime, 'DD/MM/YYYY') AS consultationtime,
    TO_CHAR(current_date, 'DD/MM/YYYY') AS fecha_actual,
    treatment.externalconsultation.consultationreason as motive,
     treatment.externalconsultation.observations,
      treatment.externalconsultation.physicalexam ,
       treatment.externalconsultation.referencenumber,
         treatment.externalconsultation.medicalhistory ,
    treatment.patients.name,
    treatment.patients.lastname,
    UPPER(treatment.patients.name || ' ' || treatment.patients.lastname) as fullname,
    treatment.patients.identification,
    DATE_PART('year', AGE(treatment.patients.birthdate))::int AS edad,
    CASE
        WHEN treatment.patients.gender = 'FEMALE' THEN 'FEMENINO'
        WHEN treatment.patients.gender = 'MALE' THEN 'MASCULINO'
        ELSE 'OTRO'
        END AS gender,
    treatment.doctor."name" as name_dr,
    treatment.doctor.lastname as apellido_dr,
    treatment.doctor.registernumber as regist_number,
    UPPER(treatment.doctor."name" || ' ' ||  COALESCE(treatment.doctor.lastname, '')) as fullname_dr,
    COALESCE(treatment.doctor.identification, '') as registernumber,
    UPPER(identity.business.name) as clinica,
    identity.business.logo,
    identity.business.email,
	identity.business.phone,
	identity.business.website,
    COALESCE(treatment.services.name, ' ') as medicalspeciality
FROM treatment.externalconsultation
         LEFT JOIN treatment.patients ON treatment.patients.id = treatment.externalconsultation.patient_id
         LEFT JOIN treatment.doctor ON treatment.doctor.id = treatment.externalconsultation.doctor_id
         LEFT JOIN identity.business ON identity.business.id = treatment.externalconsultation.business_id
         LEFT JOIN treatment.services ON treatment.services.id = treatment.externalconsultation.service_id

         WHERE treatment.externalconsultation.id = $P{id_consulta}::uuid
     ]]></query>
