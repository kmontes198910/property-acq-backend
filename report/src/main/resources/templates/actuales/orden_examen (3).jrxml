<jasperReport name="informe_medic" language="javascript" pageWidth="612" pageHeight="792" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="c352693a-a449-4d92-8526-37a41f118d0f">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
