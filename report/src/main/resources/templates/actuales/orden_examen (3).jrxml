	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w1" value="239"/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w2" value="756"/>
	<dataset name="Diagnostico" uuid="780501ba-06b2-421c-84fc-047ee794b034">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w1" value="272"/>
		<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w2" value="720"/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="doctorkyn"/>
		<parameter name="id_consulta" class="java.lang.String"/>
		<query language="SQL"><![CDATA[Select  (treatment.diagnosis.icdcode || ' - ' ||  treatment.diagnosis.description) as Diagnostico from  treatment.diagnosis where  treatment.diagnosis.external_consultation_id = $P{id_consulta}  ::uuid]]></query>
		<field name="diagnostico" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="diagnostico"/>
			<property name="com.jaspersoft.studio.field.label" value="diagnostico"/>
		</field>
		<group name="diagnostico">
			<expression><![CDATA[$F{diagnostico}]]></expression>
		</group>
	</dataset>
	<parameter name="id_consulta" class="java.lang.String"/>
	<query language="SQL"><![CDATA[SELECT
    TO_CHAR(treatment.externalconsultation.consultationtime, 'DD/MM/YYYY') AS consultationtime,
    treatment.externalconsultation.id,
    treatment.patients.name,
    treatment.patients.lastname,
    UPPER(treatment.patients.name || ' ' || treatment.patients.lastname) as fullname,
    treatment.patients.identification,
    DATE_PART('year', AGE(treatment.patients.birthdate))::int AS edad,
    CASE
        WHEN treatment.patients.gender = 'FEMALE' THEN 'FEMENINO'
        WHEN treatment.patients.gender = 'MALE' THEN 'MASCULINO'
        ELSE 'OTRO'
END AS gender,
    treatment.doctor."name" as name_dr,
    treatment.doctor.lastname as apellido_dr,
    treatment.doctor.registernumber as regist_number,
    UPPER(treatment.doctor."name" || ' ' ||  COALESCE(treatment.doctor.lastname, '')) as fullname_dr,
    COALESCE(treatment.doctor.identification, '') as registernumber,
    UPPER(identity.business.name) as clinica,
    identity.business.logo,
    identity.business.email,
	identity.business.phone,
	identity.business.website,
    COALESCE(treatment.services.name, ' ') as medicalspeciality,
    treatment.exam.code as examen_codigo, treatment.exam.name as examen_nombre, treatment.exam.description as examen_descripcion, treatment.exam.result,  treatment.exam.dateperformed as examen_date_performed,
    CASE WHEN treatment.exam.type = 'LAB_TESTS' THEN 'Examen de Laboratorio' 
         WHEN treatment.exam.type = 'CARDIAC_NEURO' THEN 'Examen cardíaco/neurológico'
         WHEN treatment.exam.type = 'ENDOSCOPIC' THEN 'Examen endoscópico'
         WHEN treatment.exam.type = 'ORGAN_SPECIFIC' THEN 'Examen específico de órgano'
         WHEN treatment.exam.type = 'ALLERGY_SENSITIVITY' THEN 'Examen de alergia y sensibilidad'
         WHEN treatment.exam.type = 'OPHTHALMOLOGY' THEN 'Examen oftalmológico'
    ELSE 'EXAMEN' END AS type
   
FROM treatment.externalconsultation
         inner JOIN treatment.exam ON treatment.exam.external_consultation_id = treatment.externalconsultation.id
         LEFT JOIN treatment.patients ON treatment.patients.id = treatment.externalconsultation.patient_id
         LEFT JOIN treatment.doctor ON treatment.doctor.id = treatment.externalconsultation.doctor_id
         LEFT JOIN identity.business ON identity.business.id = treatment.externalconsultation.business_id
         LEFT JOIN treatment.services ON treatment.services.id = treatment.externalconsultation.service_id
 WHERE treatment.externalconsultation.id  = $P{id_consulta}::uuid]]></query>
