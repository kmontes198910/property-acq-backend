	<columnHeader height="210" splitType="Stretch">
		<element kind="textField" uuid="4e3310fc-cdc6-430e-91e7-6a2823aaa4db" x="0" y="100" width="510" height="110" markup="styled" fontName="SansSerif" fontSize="12.0">
			<expression><![CDATA["<b>He recibido información clara y suficiente sobre:</b>\n" 
                + "• Objetivo y justificación del procedimiento\n"
                + "• Riesgos y complicaciones potenciales\n"
                + "• Alternativas terapéuticas\n"
                + "• Tipo de anestesia requerida\n"
                + "• Cuidados y seguimiento postoperatorio"]]></expression>
		</element>
		<element kind="textField" uuid="9853a342-3dd8-4e41-9879-14c44ce5fd00" x="0" y="3" width="510" height="96" markup="styled" fontName="SansSerif" fontSize="12.0">
			<expression><![CDATA["Yo, "+"<b>"+$F{firstname} + " " +$F{lastname}+ "</b>"+"\n" 
                + "Con cédula/pasaporte N.º "+ "<b>"+$F{ident_pac}+ "</b>"+"\n"
                + "He sido informado/a por el Dr./Dra. "+ "<b>"+$F{cirujano}+ "</b>"+"\n"
                + "Acerca del acerca del procedimiento quirúrgico denominado: "+ "<b>"+$F{surgery_type_name}+ "</b>"]]></expression>
		</element>
