			<expression><![CDATA["<b>He recibido información clara y suficiente sobre:</b>\n" 
                + "• Tipo y propósito de la anestesia\n"
                + "• Posibles efectos secundarios y riesgos\n"
                + "• Complicaciones asociadas al procedimiento\n"
                + "• Alternativas disponibles\n"
                + "• Cuidados post-anestésicos"]]></expression>
		</element>
		<element kind="textField" uuid="9853a342-3dd8-4e41-9879-14c44ce5fd00" x="0" y="3" width="510" height="96" markup="styled" fontName="SansSerif" fontSize="12.0">
			<expression><![CDATA["Yo, "+"<b>"+$F{firstname} + " " +$F{lastname}+ "</b>"+"\n" 
                + "Con cédula/pasaporte N.º "+ "<b>"+$F{ident_pac}+ "</b>"+"\n"
                + "He sido informado/a por el anestesiólogo Dr./Dra. "+ "<b>"+$F{anestesiólogo}+ "</b>"+"\n"
                + "Acerca del procedimiento anestésico que se me administrará: "+ "<b>"+$F{tipo_anestesia_descripcion}+ "</b>"]]></expression>
		</element>
