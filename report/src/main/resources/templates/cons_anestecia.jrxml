<jasperReport name="Blank_A4_2" language="javascript" columnCount="1" pageWidth="595" pageHeight="842" columnWidth="515" leftMargin="40" rightMargin="40" topMargin="20" bottomMargin="20" uuid="67ef7b8c-8d0b-43a9-807a-5865cadd888a">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="doctorkyn"/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w1" value="243"/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w2" value="752"/>
	<property name="net.sf.jasperreports.export.pdf.force.linebreak.policy" value="true"/>
	<property name="net.sf.jasperreports.export.pdf.embedded" value="true"/>
	<parameter name="surgery_id" class="java.lang.String"/>
	<query language="SQL"><![CDATA[Select 
BS.name as clinica,
BS.logo,
PT.firstname,
PT.lastname,
PT.identification as ident_pac,
COALESCE(MT.member_name, '')  as Anestesiólogo,
AN.anesthesia_type as Tipo_anestecia,
    CASE 
        WHEN AN.anesthesia_type = 'general_balanceada' THEN 'General Balanceada'
        WHEN AN.anesthesia_type = 'general_dispositivo_supragloticos' THEN 'General Dispositivo Supraglóticos (Empleo de Máscaras Laríngeas)'
        WHEN AN.anesthesia_type = 'general_endotraqueal' THEN 'General Endotraqueal (Orotraqueal)'
        WHEN AN.anesthesia_type = 'general_endovenosa_total' THEN 'General Endovenosa Total (TIVA)'
        WHEN AN.anesthesia_type = 'multimodal' THEN 'Multimodal (General y Neuroaxial)'
        WHEN AN.anesthesia_type = 'neuroaxial_peridural' THEN 'Neuroaxial Peridural (Epidural, Caudal)'
        WHEN AN.anesthesia_type = 'neuroaxial_subaracnoidea' THEN 'Neuroaxial Subaracnoidea (Intratecal o Raquídea)'
        WHEN AN.anesthesia_type = 'regional_infiltrativa' THEN 'Regional Infiltrativa (Local Infiltrativa)'
        WHEN AN.anesthesia_type = 'regional_plexal' THEN 'Regional Plexal (Bloqueo)'
        WHEN AN.anesthesia_type = 'regional_topica' THEN 'Regional Tópica'
        WHEN AN.anesthesia_type = 'regional_troncular' THEN 'Regional Troncular'
        WHEN AN.anesthesia_type = 'tiva_compleja' THEN 'TIVA compleja'
        WHEN AN.anesthesia_type = 'tiva_simple' THEN 'TIVA simple'
        ELSE 'No definido'
    END AS tipo_anestesia_descripcion

from surgery.surgeries SUR
inner join patient.patients PT on SUR.patient_id = PT.id
inner join identity.business BS on SUR.business_id = BS.id
left join surgery.medical_teams MT on MT.surgery_id = SUR.id and MT.role = 'anesthesiologist'
left join surgery.anesthesia AN on AN.surgery_id = SUR.id

WHERE SUR.id =   $P{surgery_id} ::uuid]]></query>
