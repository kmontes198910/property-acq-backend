			<expression><![CDATA["CONSENTIMIENTO INFORMADO PARA PROCEDIMIENTO DE ANESTESIA"]]></expression>
		</element>
		<element kind="textField" uuid="306c1a1c-33fb-4b84-ac6d-15400b0b5c69" x="0" y="130" width="510" height="30" forecolor="#555555" fontName="SansSerif" fontSize="16.0" bold="true" vTextAlign="Middle">
